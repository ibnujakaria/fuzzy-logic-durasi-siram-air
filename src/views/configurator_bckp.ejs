<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  .cfg-wrap {
    display: flex;
    min-height: 100vh;
  }

  /* --- Sidebar --- */
  .cfg-sidebar {
    width: 200px;
    flex-shrink: 0;
    background: #0a1628;
    border-right: 1px solid #1e293b;
    padding: 20px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }
  .cfg-sidebar-logo {
    font-size: 0.68rem;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0 8px 4px;
  }
  .cfg-sidebar-title {
    font-size: 0.7rem;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 14px 8px 4px;
  }
  .cfg-nav-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    width: 100%;
    padding: 9px 12px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: #94a3b8;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s, color 0.12s;
  }
  .cfg-nav-item:hover { background: #1e293b; color: #e2e8f0; }
  .cfg-nav-item.active { background: rgba(56,189,248,0.1); color: #38bdf8; }
  .cfg-nav-label { font-size: 0.875rem; font-weight: 500; }
  .cfg-nav-unit { font-size: 0.72rem; color: #475569; }
  .cfg-nav-item.active .cfg-nav-unit { color: #7dd3fc; }

  .cfg-sidebar-spacer { flex: 1; }
  .btn-reset {
    width: 100%;
    padding: 8px 12px;
    border-radius: 7px;
    border: 1px solid #334155;
    background: transparent;
    color: #64748b;
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.12s;
    margin-top: 8px;
  }
  .btn-reset:hover { border-color: #ef4444; color: #ef4444; background: rgba(239,68,68,0.06); }

  /* --- Main --- */
  .cfg-main {
    flex: 1;
    padding: 28px 32px;
    min-width: 0;
  }
  .cfg-back { font-size: 0.8rem; color: #475569; text-decoration: none; display: inline-block; margin-bottom: 14px; }
  .cfg-back:hover { color: #38bdf8; }
  .cfg-main-header { margin-bottom: 24px; padding-bottom: 14px; border-bottom: 1px solid #1e293b; }
  .cfg-main-header h1 { font-size: 1.4rem; color: #7dd3fc; }
  .cfg-range { font-size: 0.82rem; color: #64748b; margin-top: 3px; display: block; }

  /* --- Sets grid (auto-fit, min 200px per col) --- */
  .sets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 20px;
  }
  @media (min-width: 768px) {
    .sets-grid { grid-template-columns: repeat(5, 1fr); }
  }

  .set-col {
    background: #111827;
    border: 1px solid #1e293b;
    border-radius: 10px;
    padding: 18px 16px;
  }
  .set-col-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }
  .set-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .set-col-title { font-size: 0.95rem; font-weight: 600; color: #e2e8f0; }

  /* --- Form elements --- */
  .form-group { display: flex; flex-direction: column; gap: 4px; }
  .form-group label {
    font-size: 0.68rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 600;
  }
  .form-group select,
  .form-group input[type="number"] {
    padding: 7px 9px;
    border-radius: 6px;
    border: 1px solid #1e293b;
    background: #0f172a;
    color: #e2e8f0;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.12s;
    width: 100%;
  }
  .form-group select:focus,
  .form-group input[type="number"]:focus { border-color: #38bdf8; }

  .fn-row { margin-bottom: 12px; }

  .param-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  /* --- Combined chart --- */
  .chart-section {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 10px;
    padding: 8px 4px 4px;
  }

  /* --- Rules table --- */
  .rules-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .rules-table th {
    padding: 8px 10px;
    text-align: left;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: #64748b;
    border-bottom: 1px solid #1e293b;
    white-space: nowrap;
  }
  .rules-table td {
    padding: 5px 6px;
    border-bottom: 1px solid #0f172a;
    vertical-align: middle;
  }
  .rules-table tbody tr:last-child td { border-bottom: none; }
  .rules-table select {
    padding: 5px 8px;
    border-radius: 5px;
    border: 1px solid #1e293b;
    background: #0f172a;
    color: #e2e8f0;
    font-size: 0.82rem;
    outline: none;
    width: 100%;
    min-width: 90px;
    cursor: pointer;
  }
  .rules-table select:focus { border-color: #38bdf8; }
  .arrow-cell { color: #38bdf8; text-align: center; padding: 5px 8px; font-size: 1rem; }
  .num-cell { color: #475569; text-align: center; width: 32px; font-size: 0.8rem; }
  .btn-del-rule {
    background: transparent;
    border: 1px solid #334155;
    color: #64748b;
    border-radius: 5px;
    width: 28px;
    height: 28px;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    transition: all 0.12s;
  }
  .btn-del-rule:hover { border-color: #ef4444; color: #ef4444; background: rgba(239,68,68,0.06); }
  .btn-add-rule {
    margin-top: 14px;
    padding: 8px 18px;
    border-radius: 7px;
    border: 1px dashed #334155;
    background: transparent;
    color: #64748b;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.12s;
  }
  .btn-add-rule:hover { border-color: #38bdf8; color: #38bdf8; }

  /* --- C++ code view --- */
  .code-actions { display: flex; justify-content: flex-end; margin-bottom: 8px; }
  .btn-copy-code {
    padding: 6px 16px;
    border-radius: 6px;
    border: 1px solid #334155;
    background: transparent;
    color: #94a3b8;
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.12s;
  }
  .btn-copy-code:hover { border-color: #38bdf8; color: #38bdf8; }
  .btn-copy-code.copied { border-color: #22c55e; color: #22c55e; }
  .code-block {
    background: #0d1117;
    border: 1px solid #1e293b;
    border-radius: 10px;
    overflow: auto;
    max-height: 70vh;
  }
  .code-block pre { margin: 0; }
  .code-block pre code.hljs { border-radius: 10px; font-size: 0.82rem; line-height: 1.55; }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>

<div class="cfg-wrap" x-data="configuratorApp()" x-init="init()">

  <!-- Sidebar -->
  <aside class="cfg-sidebar">
    <div class="cfg-sidebar-logo">Fuzzy Configurator</div>
    <div class="cfg-sidebar-title">Variabel Input</div>

    <template x-for="key in inputKeys" :key="key">
      <button class="cfg-nav-item" :class="{ active: selected === key }" @click="selectInput(key)">
        <span class="cfg-nav-label" x-text="config[key].label"></span>
        <span class="cfg-nav-unit" x-text="'(' + config[key].unit + ')'"></span>
      </button>
    </template>

    <div class="cfg-sidebar-title" style="margin-top:8px">Variabel Output</div>

    <template x-for="key in outputKeys" :key="key">
      <button class="cfg-nav-item" :class="{ active: selected === key }" @click="selectInput(key)">
        <span class="cfg-nav-label" x-text="config[key].label"></span>
        <span class="cfg-nav-unit" x-text="'(' + config[key].unit + ')'"></span>
      </button>
    </template>

    <div class="cfg-sidebar-title" style="margin-top:8px">Aturan</div>
    <button class="cfg-nav-item" :class="{ active: selected === 'aturan' }" @click="selectInput('aturan')">
      <span class="cfg-nav-label">Aturan Inferensi</span>
      <span class="cfg-nav-unit" x-text="'(' + rules.length + ' aturan)'"></span>
    </button>

    <div class="cfg-sidebar-title" style="margin-top:8px">Export</div>
    <button class="cfg-nav-item" :class="{ active: selected === 'cpp' }" @click="selectInput('cpp')">
      <span class="cfg-nav-label">Kode C++</span>
      <span class="cfg-nav-unit">watering_config.cpp</span>
    </button>

    <div class="cfg-sidebar-spacer"></div>
    <button class="btn-reset" @click="resetToDefaults()">Reset Default</button>
  </aside>

  <!-- Main -->
  <main class="cfg-main">
    <a href="/" class="cfg-back">&larr; Beranda</a>

    <!-- Config view -->
    <div x-show="!isRulesView() && !isCppView()">
      <div class="cfg-main-header">
        <h1 x-text="config[selected] ? config[selected].label : ''"></h1>
        <span class="cfg-range"
          x-text="config[selected] ? 'Rentang: ' + getRange(selected).min + ' – ' + getRange(selected).max + ' ' + config[selected].unit : ''">
        </span>
      </div>

      <div class="sets-grid">
        <template x-for="set in (config[selected] ? config[selected].sets : [])" :key="set.key">
          <div class="set-col">

            <div class="set-col-header">
              <div class="set-dot" :style="'background:' + set.color"></div>
              <span class="set-col-title" x-text="set.label"></span>
            </div>

            <div class="fn-row">
              <div class="form-group">
                <label>Fungsi</label>
                <select x-model="set.fn" @change="onParamChange()">
                  <option value="segitiga">Segitiga</option>
                  <option value="trapesium">Trapesium</option>
                </select>
              </div>
            </div>

            <div class="param-grid">
              <div class="form-group">
                <label>a</label>
                <input type="number" step="any" x-model.number="set.a" @input="onParamChange()" />
              </div>
              <div class="form-group">
                <label>b</label>
                <input type="number" step="any" x-model.number="set.b" @input="onParamChange()" />
              </div>
              <div class="form-group">
                <label>c</label>
                <input type="number" step="any" x-model.number="set.c" @input="onParamChange()" />
              </div>
              <div class="form-group" x-show="set.fn === 'trapesium'">
                <label>d</label>
                <input type="number" step="any" x-model.number="set.d" @input="onParamChange()" />
              </div>
            </div>

          </div>
        </template>
      </div>

      <div class="chart-section">
        <div id="chart-cfg-combined"></div>
      </div>
    </div>

    <!-- Rules view -->
    <div x-show="isRulesView()">
      <div class="cfg-main-header">
        <h1>Aturan Inferensi</h1>
        <span class="cfg-range" x-text="rules.length + ' aturan aktif'"></span>
      </div>

      <div style="overflow-x: auto;">
        <table class="rules-table">
          <thead>
            <tr>
              <th class="num-cell">#</th>
              <th x-text="config.kelembapanTanah.label"></th>
              <th x-text="config.suhuUdara.label"></th>
              <th x-text="config.kelembapanUdara.label"></th>
              <th x-text="config.curahHujan.label"></th>
              <th></th>
              <th x-text="config.durasiSiram.label"></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <template x-for="(rule, idx) in rules" :key="rule.id">
              <tr>
                <td class="num-cell" x-text="idx + 1"></td>
                <td>
                  <select @change="rule.conditions.kelembapanTanah = $event.target.value; saveRules()">
                    <option value="*" :selected="rule.conditions.kelembapanTanah === '*'">— Semua —</option>
                    <template x-for="s in config.kelembapanTanah.sets" :key="s.key">
                      <option :value="s.key" :selected="rule.conditions.kelembapanTanah === s.key" x-text="s.label"></option>
                    </template>
                  </select>
                </td>
                <td>
                  <select @change="rule.conditions.suhuUdara = $event.target.value; saveRules()">
                    <option value="*" :selected="rule.conditions.suhuUdara === '*'">— Semua —</option>
                    <template x-for="s in config.suhuUdara.sets" :key="s.key">
                      <option :value="s.key" :selected="rule.conditions.suhuUdara === s.key" x-text="s.label"></option>
                    </template>
                  </select>
                </td>
                <td>
                  <select @change="rule.conditions.kelembapanUdara = $event.target.value; saveRules()">
                    <option value="*" :selected="rule.conditions.kelembapanUdara === '*'">— Semua —</option>
                    <template x-for="s in config.kelembapanUdara.sets" :key="s.key">
                      <option :value="s.key" :selected="rule.conditions.kelembapanUdara === s.key" x-text="s.label"></option>
                    </template>
                  </select>
                </td>
                <td>
                  <select @change="rule.conditions.curahHujan = $event.target.value; saveRules()">
                    <option value="*" :selected="rule.conditions.curahHujan === '*'">— Semua —</option>
                    <template x-for="s in config.curahHujan.sets" :key="s.key">
                      <option :value="s.key" :selected="rule.conditions.curahHujan === s.key" x-text="s.label"></option>
                    </template>
                  </select>
                </td>
                <td class="arrow-cell">→</td>
                <td>
                  <select @change="rule.output = $event.target.value; saveRules()">
                    <template x-for="s in config.durasiSiram.sets" :key="s.key">
                      <option :value="s.key" :selected="rule.output === s.key" x-text="s.label"></option>
                    </template>
                  </select>
                </td>
                <td>
                  <button class="btn-del-rule" @click="deleteRule(idx)" title="Hapus aturan">×</button>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
      <button class="btn-add-rule" @click="addRule()">+ Tambah Aturan</button>
    </div>

    <!-- C++ export view -->
    <div x-show="isCppView()">
      <div class="cfg-main-header">
        <h1>Kode C++</h1>
        <span class="cfg-range">watering_config.cpp</span>
      </div>
      <div class="code-actions">
        <button class="btn-copy-code" :class="{ copied: copied }" @click="copyCode()"
          x-text="copied ? '✓ Tersalin!' : 'Salin Kode'"></button>
      </div>
      <div class="code-block" x-show="!cppLoading && !cppError">
        <pre><code id="cpp-output" class="language-cpp"></code></pre>
      </div>
      <div x-show="cppLoading" style="color:#94a3b8;padding:20px">Memuat...</div>
      <div x-show="cppError" style="color:#f87171;padding:20px" x-text="cppError"></div>
    </div>

  </main>
</div>

<script>
  function configuratorApp() {
    var DEFAULTS = {
      kelembapanTanah: {
        label: 'Kelembapan Tanah', unit: '%',
        sets: [
          { key: 'kering', label: 'Kering', fn: 'trapesium', a: 0,  b: 0,  c: 20,  d: 40,  color: '#f97316' },
          { key: 'lembap', label: 'Lembap', fn: 'segitiga',  a: 30, b: 50, c: 70,  d: 70,  color: '#22d3ee' },
          { key: 'basah',  label: 'Basah',  fn: 'trapesium', a: 60, b: 80, c: 100, d: 100, color: '#3b82f6' },
        ]
      },
      suhuUdara: {
        label: 'Suhu Udara', unit: '°C',
        sets: [
          { key: 'dingin', label: 'Dingin', fn: 'trapesium', a: 0,  b: 0,  c: 18, d: 25, color: '#22d3ee' },
          { key: 'hangat', label: 'Hangat', fn: 'segitiga',  a: 22, b: 28, c: 34, d: 34, color: '#facc15' },
          { key: 'panas',  label: 'Panas',  fn: 'trapesium', a: 32, b: 38, c: 50, d: 50, color: '#ef4444' },
        ]
      },
      kelembapanUdara: {
        label: 'Kelembapan Udara', unit: '%',
        sets: [
          { key: 'rendah', label: 'Rendah', fn: 'trapesium', a: 0,  b: 0,  c: 25,  d: 45,  color: '#f97316' },
          { key: 'sedang', label: 'Sedang', fn: 'segitiga',  a: 35, b: 55, c: 75,  d: 75,  color: '#22d3ee' },
          { key: 'tinggi', label: 'Tinggi', fn: 'trapesium', a: 65, b: 80, c: 100, d: 100, color: '#3b82f6' },
        ]
      },
      curahHujan: {
        label: 'Curah Hujan', unit: 'mm',
        sets: [
          { key: 'tidak_ada', label: 'Tidak Ada', fn: 'trapesium', a: 0,   b: 0,   c: 0.1, d: 0.5, color: '#facc15' },
          { key: 'ringan',    label: 'Ringan',    fn: 'segitiga',  a: 0.3, b: 1.5, c: 4,   d: 4,   color: '#22d3ee' },
          { key: 'lebat',     label: 'Lebat',     fn: 'trapesium', a: 3,   b: 6,   c: 50,  d: 50,  color: '#3b82f6' },
        ]
      },
      durasiSiram: {
        label: 'Durasi Siram', unit: 'detik',
        sets: [
          { key: 'nol',           label: 'Nol',           fn: 'trapesium', a: 0,   b: 0,   c: 0,   d: 20,  color: '#94a3b8' },
          { key: 'pendek',        label: 'Pendek',        fn: 'segitiga',  a: 10,  b: 60,  c: 110, d: 110, color: '#22d3ee' },
          { key: 'sedang',        label: 'Sedang',        fn: 'segitiga',  a: 80,  b: 150, c: 220, d: 220, color: '#facc15' },
          { key: 'panjang',       label: 'Panjang',       fn: 'segitiga',  a: 180, b: 240, c: 280, d: 280, color: '#f97316' },
          { key: 'sangat_panjang', label: 'Sangat Panjang', fn: 'trapesium', a: 250, b: 280, c: 300, d: 300, color: '#ef4444' },
        ]
      },
    };

    var DEFAULT_RULES = [
      { id: 1, conditions: { kelembapanTanah: 'basah',  suhuUdara: 'dingin', kelembapanUdara: 'tinggi', curahHujan: 'lebat'     }, output: 'nol'            },
      { id: 2, conditions: { kelembapanTanah: 'lembap', suhuUdara: 'hangat', kelembapanUdara: 'sedang', curahHujan: 'ringan'    }, output: 'sedang'         },
      { id: 3, conditions: { kelembapanTanah: 'kering', suhuUdara: 'panas',  kelembapanUdara: 'rendah', curahHujan: 'tidak_ada' }, output: 'sangat_panjang' },
    ];

    return {
      inputKeys: ['kelembapanTanah', 'suhuUdara', 'kelembapanUdara', 'curahHujan'],
      outputKeys: ['durasiSiram'],
      selected: 'kelembapanTanah',
      config: null,
      rules: [],
      copied: false,
      cppLoading: false,
      cppError: '',

      allKeys() {
        return this.inputKeys.concat(this.outputKeys);
      },

      isRulesView() { return this.selected === 'aturan'; },
      isCppView()   { return this.selected === 'cpp'; },

      getRange(key) {
        var sets = this.config[key].sets;
        var vals = sets.reduce(function(acc, s) {
          return acc.concat([s.a, s.b, s.c, s.d]);
        }, []);
        return { min: Math.min.apply(null, vals), max: Math.max.apply(null, vals) };
      },

      init() {
        var defaults = JSON.parse(JSON.stringify(DEFAULTS));
        var parsed = null;
        try {
          var raw = localStorage.getItem('watering-configurator');
          if (raw) parsed = JSON.parse(raw);
        } catch (e) {
          localStorage.removeItem('watering-configurator');
        }
        var allKeys = Object.keys(defaults);
        this.config = {};
        for (var i = 0; i < allKeys.length; i++) {
          var k = allKeys[i];
          var entry = parsed && parsed[k];
          var valid = entry && Array.isArray(entry.sets) && entry.sets.length > 0
            && typeof entry.label === 'string';
          this.config[k] = valid ? entry : defaults[k];
        }

        try {
          var rawRules = localStorage.getItem('watering-rules');
          var savedRules = rawRules ? JSON.parse(rawRules) : null;
          this.rules = (Array.isArray(savedRules) && savedRules.length > 0)
            ? savedRules
            : JSON.parse(JSON.stringify(DEFAULT_RULES));
        } catch (e) {
          localStorage.removeItem('watering-rules');
          this.rules = JSON.parse(JSON.stringify(DEFAULT_RULES));
        }

        var param = new URLSearchParams(window.location.search).get('input');
        if (param && (this.allKeys().includes(param) || param === 'aturan' || param === 'cpp')) this.selected = param;

        var self = this;
        window.addEventListener('popstate', function() {
          var p = new URLSearchParams(window.location.search).get('input');
          if (p && (self.allKeys().includes(p) || p === 'aturan' || p === 'cpp')) {
            self.selected = p;
            if (p !== 'aturan' && p !== 'cpp') self.$nextTick(function() { self.renderChart(); });
            if (p === 'cpp') self.$nextTick(function() { self.updateCppCode(); });
          }
        });

        this.$nextTick(function() {
          if (this.isCppView()) { this.updateCppCode(); }
          else { this.renderChart(); }
        }.bind(this));
      },

      selectInput(key) {
        this.selected = key;
        history.pushState(null, '', '?input=' + key);
        var self = this;
        this.$nextTick(function() {
          if (window._cfgChart) { window._cfgChart.destroy(); window._cfgChart = null; }
          setTimeout(function() {
            if (self.isCppView()) { self.updateCppCode(); }
            else { self.renderChart(); }
          }, 0);
        });
      },

      save() {
        localStorage.setItem('watering-configurator', JSON.stringify(this.config));
      },

      onParamChange() {
        this.save();
        this.$nextTick(function() {
          var chart = window._cfgChart;
          var inp = this.config[this.selected];
          var range = this.getRange(this.selected);
          if (chart) {
            chart.updateOptions({
              series: this.buildSeries(),
              xaxis: { min: range.min, max: range.max },
              colors: inp.sets.map(function(s) { return s.color; })
            });
          } else {
            this.renderChart();
          }
        }.bind(this));
      },

      sampleMf(set, min, max) {
        var steps = 200;
        var data = [];
        for (var i = 0; i <= steps; i++) {
          var x = +(min + (i / steps) * (max - min)).toFixed(5);
          var y = 0;
          var a = set.a, b = set.b, c = set.c, d = set.d;
          if (set.fn === 'segitiga') {
            if (x > a && x < c) {
              if (x <= b) y = b > a ? (x - a) / (b - a) : 1;
              else        y = c > b ? (c - x) / (c - b) : 1;
            }
          } else {
            if (x > a && x < d) {
              if (x >= b && x <= c) y = 1;
              else if (x < b) y = b > a ? (x - a) / (b - a) : 1;
              else             y = d > c ? (d - x) / (d - c) : 1;
            }
          }
          data.push({ x: x, y: +Math.max(0, Math.min(1, y)).toFixed(3) });
        }
        return data;
      },

      buildSeries() {
        if (this.isRulesView() || this.isCppView()) return [];
        var inp = this.config[this.selected];
        var range = this.getRange(this.selected);
        var self = this;
        return inp.sets.map(function(set) {
          return { name: set.label, data: self.sampleMf(set, range.min, range.max) };
        });
      },

      renderChart() {
        if (this.isRulesView() || this.isCppView()) return;
        var inp = this.config[this.selected];
        var range = this.getRange(this.selected);
        var el = document.getElementById('chart-cfg-combined');
        if (!el) return;
        if (window._cfgChart) { window._cfgChart.destroy(); window._cfgChart = null; }

        var opts = {
          chart: {
            type: 'line', height: 320, background: 'transparent',
            toolbar: { show: false }, zoom: { enabled: false },
            animations: { enabled: false }
          },
          series: this.buildSeries(),
          stroke: { width: 2.5, curve: 'straight' },
          colors: inp.sets.map(function(s) { return s.color; }),
          xaxis: {
            type: 'numeric', min: range.min, max: range.max, tickAmount: 6,
            title: { text: inp.label + ' (' + inp.unit + ')', style: { color: '#94a3b8', fontSize: '12px' } },
            labels: {
              style: { colors: '#64748b', fontSize: '11px' },
              formatter: function(val) { return +parseFloat(val).toFixed(3) + ''; }
            },
            axisBorder: { color: '#334155' }, axisTicks: { color: '#334155' }
          },
          yaxis: {
            min: 0, max: 1.05, tickAmount: 4,
            title: { text: 'μ(x)', style: { color: '#94a3b8', fontSize: '12px' } },
            labels: { style: { colors: '#64748b' }, formatter: function(v) { return v.toFixed(1); } }
          },
          legend: {
            position: 'top', horizontalAlign: 'center',
            labels: { colors: '#94a3b8' }, fontSize: '12px', markers: { size: 6 }
          },
          grid: { borderColor: '#1e293b', strokeDashArray: 3 },
          tooltip: {
            theme: 'dark',
            x: { formatter: function(v) { return inp.unit + ': ' + v; } },
            y: { formatter: function(v) { return 'μ = ' + (v != null ? v.toFixed(3) : '0'); } }
          },
        };

        window._cfgChart = new ApexCharts(el, opts);
        window._cfgChart.render();
      },

      updateCppCode() {
        var self = this;
        this.cppLoading = true;
        this.cppError = '';
        fetch('/api/generate-cpp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ config: this.config, rules: this.rules }),
        })
          .then(function(res) {
            if (!res.ok) throw new Error('Server error ' + res.status);
            return res.text();
          })
          .then(function(code) {
            self.cppLoading = false;
            self.$nextTick(function() {
              var el = document.getElementById('cpp-output');
              if (!el) return;
              el.removeAttribute('data-highlighted');
              el.textContent = code;
              if (typeof hljs !== 'undefined') hljs.highlightElement(el);
            });
          })
          .catch(function(e) {
            self.cppLoading = false;
            self.cppError = 'Gagal menghasilkan kode: ' + (e.message || e);
          });
      },

      copyCode() {
        var el = document.getElementById('cpp-output');
        if (!el) return;
        var self = this;
        navigator.clipboard.writeText(el.textContent).then(function() {
          self.copied = true;
          setTimeout(function() { self.copied = false; }, 2000);
        });
      },

      saveRules() {
        localStorage.setItem('watering-rules', JSON.stringify(this.rules));
      },

      addRule() {
        this.rules.push({
          id: Date.now(),
          conditions: { kelembapanTanah: '*', suhuUdara: '*', kelembapanUdara: '*', curahHujan: '*' },
          output: this.config.durasiSiram.sets[0].key,
        });
        this.saveRules();
      },

      deleteRule(idx) {
        this.rules.splice(idx, 1);
        this.saveRules();
      },

      resetToDefaults() {
        this.config = JSON.parse(JSON.stringify(DEFAULTS));
        this.save();
        this.rules = JSON.parse(JSON.stringify(DEFAULT_RULES));
        this.saveRules();
        this.$nextTick(function() {
          if (this.isCppView()) { this.updateCppCode(); }
          else { this.renderChart(); }
        }.bind(this));
      },
    };
  }
</script>
