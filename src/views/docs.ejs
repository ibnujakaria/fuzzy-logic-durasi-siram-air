          <tbody>
            <tr><td>14</td><td>Panas</td><td>Rendah</td><td>Panjang</td></tr>
            <tr><td>15</td><td>Panas</td><td>Sedang</td><td>Sedang</td></tr>
            <tr><td>16</td><td>Panas</td><td>Tinggi</td><td>Pendek</td></tr>
            <tr><td>17</td><td>Hangat</td><td>Rendah</td><td>Sedang</td></tr>
            <tr><td>18</td><td>Hangat</td><td>Sedang</td><td>Pendek</td></tr>
