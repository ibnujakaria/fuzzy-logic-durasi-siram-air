<%- include('docs/charts') %>

<style>
  header { text-align: center; margin-bottom: 32px; }
  header h1 { font-size: 1.8rem; color: #38bdf8; }
  header p { color: #94a3b8; margin-top: 4px; }
  .back-link { color: #94a3b8; text-decoration: none; font-size: 0.85rem; }
  .back-link:hover { color: #38bdf8; }
  .section {
    background: #1e293b; border: 1px solid #334155; border-radius: 12px;
    margin-bottom: 16px; overflow: hidden;
  }
  .section-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 20px; cursor: pointer; user-select: none;
  }
  .section-header:hover { background: rgba(255,255,255,0.03); }
  .section-header h2 { font-size: 1.05rem; color: #7dd3fc; margin: 0; }
  .section-arrow {
    color: #94a3b8; font-size: 0.8rem; transition: transform 0.2s;
  }
  .section-body { padding: 0 20px 20px; }
  .section-body p { color: #cbd5e1; font-size: 0.9rem; line-height: 1.7; margin-bottom: 12px; }
  .section-body ul { color: #cbd5e1; font-size: 0.9rem; line-height: 1.7; padding-left: 20px; margin-bottom: 12px; }
  .section-body li { margin-bottom: 4px; }
  .table-wrap { overflow-x: auto; margin: 12px 0; -webkit-overflow-scrolling: touch; }
  .data-table {
    width: 100%; border-collapse: collapse; font-size: 0.85rem; min-width: 400px;
  }
  .data-table th {
    text-align: left; padding: 10px 12px; background: rgba(255,255,255,0.05);
    color: #7dd3fc; border-bottom: 1px solid #334155; font-weight: 600;
  }
  .data-table td {
    padding: 8px 12px; color: #cbd5e1; border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .data-table tr:last-child td { border-bottom: none; }
  .formula {
    background: #0f172a; border: 1px solid #334155; border-radius: 8px;
    padding: 14px 18px; font-family: 'Courier New', monospace; font-size: 0.85rem;
    color: #67e8f9; margin: 12px 0; overflow-x: auto;
  }
  .subsection { margin-top: 16px; }
  .subsection h3 { font-size: 0.95rem; color: #e2e8f0; margin-bottom: 8px; }
  .note {
    background: rgba(56,189,248,0.08); border-left: 3px solid #38bdf8;
    padding: 12px 16px; border-radius: 0 8px 8px 0; margin: 12px 0;
    font-size: 0.85rem; color: #94a3b8;
  }
  .chart-container {
    background: #0f172a; border: 1px solid #334155; border-radius: 8px;
    padding: 8px 4px; margin: 16px 0;
  }
</style>

<div class="container" x-data="docsApp()">

  <header>
    <a href="/" class="back-link">&larr; Kembali ke Beranda</a>
    <h1>Dokumentasi Fuzzy Logic</h1>
    <p>Penjelasan lengkap sistem inferensi fuzzy untuk penyiraman tanaman</p>
  </header>

  <%- include('docs/overview') %>
  <%- include('docs/inputs') %>
  <%- include('docs/output') %>
  <%- include('docs/membership') %>
  <%- include('docs/rules') %>
  <%- include('docs/inference') %>
  <%- include('docs/example') %>

</div>
