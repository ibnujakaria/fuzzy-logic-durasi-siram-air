<style>
  header { text-align: center; margin-bottom: 32px; }
  header h1 { font-size: 1.8rem; color: #38bdf8; }
  header p { color: #94a3b8; margin-top: 4px; }
  .back-link { color: #94a3b8; text-decoration: none; font-size: 0.85rem; }
  .back-link:hover { color: #38bdf8; }
  .form-card {
    background: linear-gradient(135deg, #1e3a5f, #1e293b);
    border-radius: 12px; padding: 28px; margin-bottom: 24px;
    border: 1px solid #334155;
  }
  .form-card h2 { font-size: 1.1rem; color: #7dd3fc; margin-bottom: 20px; }
  .form-group { margin-bottom: 16px; }
  .form-group label {
    display: block; font-size: 0.85rem; color: #94a3b8;
    margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .form-group input, .form-group select {
    width: 100%; padding: 10px 14px; border-radius: 8px;
    border: 1px solid #334155; background: #0f172a; color: #e2e8f0;
    font-size: 1rem; outline: none; transition: border-color 0.15s;
  }
  .form-group input:focus, .form-group select:focus { border-color: #38bdf8; }
  .form-group .hint { font-size: 0.75rem; color: #64748b; margin-top: 4px; }
  .btn-fuzzify {
    width: 100%; padding: 12px; border: none; border-radius: 8px;
    background: linear-gradient(135deg, #0284c7, #0369a1); color: #fff;
    font-size: 1rem; font-weight: 600; cursor: pointer;
    transition: opacity 0.15s; margin-top: 8px;
  }
  .btn-fuzzify:hover { opacity: 0.9; }
  .btn-fuzzify:disabled { opacity: 0.5; cursor: not-allowed; }
  .location-card {
    background: linear-gradient(135deg, #1e3a5f, #1e293b);
    border-radius: 12px; padding: 20px; margin-bottom: 24px;
    border: 1px solid #334155;
  }
  .location-card h2 { font-size: 1.1rem; color: #7dd3fc; margin-bottom: 8px; }
  .location-detail { display: flex; flex-wrap: wrap; gap: 12px 24px; font-size: 0.9rem; color: #94a3b8; }
  .result-card {
    background: linear-gradient(135deg, #0c4a6e, #164e63);
    border-radius: 12px; padding: 24px; margin-bottom: 24px;
    border: 1px solid #155e75;
  }
  .result-card h2 { font-size: 1.1rem; color: #7dd3fc; margin-bottom: 16px; }
  .result-duration { text-align: center; padding: 20px; }
  .result-duration .duration-value { font-size: 3rem; font-weight: 700; color: #fff; }
  .result-duration .duration-label { font-size: 1rem; color: #67e8f9; margin-top: 4px; }
  .result-inputs {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 10px; margin-top: 16px;
  }
  .result-input-item {
    background: rgba(255,255,255,0.05); border-radius: 8px; padding: 10px; text-align: center;
  }
  .result-input-item .ri-label { font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; }
  .result-input-item .ri-value { font-size: 1rem; font-weight: 600; color: #e2e8f0; margin-top: 2px; }
  .membership-section { margin-top: 20px; }
  .membership-section h3 { font-size: 0.9rem; color: #7dd3fc; margin-bottom: 12px; }
  .membership-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }
  .membership-var {
    background: rgba(255,255,255,0.05); border-radius: 8px; padding: 14px;
  }
  .membership-var .mv-title { font-size: 0.8rem; color: #7dd3fc; font-weight: 600; margin-bottom: 8px; }
  .membership-bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .membership-bar-row .mb-label { font-size: 0.75rem; color: #94a3b8; min-width: 60px; }
  .membership-bar-row .mb-track {
    flex: 1; height: 8px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden;
  }
  .membership-bar-row .mb-fill { height: 100%; border-radius: 4px; transition: width 0.3s; }
  .membership-bar-row .mb-value { font-size: 0.75rem; color: #e2e8f0; min-width: 36px; text-align: right; }
  .rules-list { margin-top: 16px; }
  .rules-list h3 { font-size: 0.9rem; color: #7dd3fc; margin-bottom: 10px; }
  .rule-item {
    background: rgba(255,255,255,0.05); border-radius: 6px; padding: 8px 12px;
    margin-bottom: 6px; font-size: 0.8rem; color: #94a3b8;
    display: flex; justify-content: space-between; align-items: center;
  }
  .rule-item .rule-strength {
    color: #34d399; font-weight: 600; min-width: 50px; text-align: right;
  }
  .rain-source-toggle { display: flex; gap: 8px; margin-bottom: 12px; }
  .rain-source-btn {
    flex: 1; padding: 10px; border: 1px solid #334155; border-radius: 8px;
    background: #0f172a; color: #94a3b8; font-size: 0.85rem;
    cursor: pointer; text-align: center; transition: all 0.15s;
  }
  .rain-source-btn:hover { border-color: #38bdf8; }
  .rain-source-btn.active { border-color: #38bdf8; background: rgba(56,189,248,0.1); color: #38bdf8; }
  .rain-preview {
    background: rgba(255,255,255,0.03); border: 1px solid #334155;
    border-radius: 8px; padding: 16px; margin-top: 12px;
  }
  .rain-preview h3 { font-size: 0.85rem; color: #7dd3fc; margin-bottom: 12px; }
  .rain-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 10px;
  }
  .rain-item {
    background: rgba(255,255,255,0.05); border-radius: 8px; padding: 12px; text-align: center;
    cursor: pointer; border: 1px solid transparent; transition: border-color 0.15s;
  }
  .rain-item:hover { border-color: #334155; }
  .rain-item.selected { border-color: #38bdf8; background: rgba(56,189,248,0.08); }
  .rain-item .rain-time { font-size: 0.8rem; color: #94a3b8; }
  .rain-item .rain-icon { font-size: 1.3rem; margin: 4px 0; }
  .rain-item .rain-desc { font-size: 0.8rem; color: #67e8f9; }
  .rain-item .rain-detail { font-size: 0.75rem; color: #94a3b8; margin-top: 4px; }
  .rain-empty { color: #94a3b8; text-align: center; padding: 16px; font-size: 0.85rem; }
  .loading { text-align: center; padding: 16px; color: #94a3b8; }
  .error { text-align: center; padding: 16px; color: #f87171; }
  .chart-container {
    background: #0f172a; border: 1px solid #334155; border-radius: 8px;
    padding: 8px 4px; margin: 12px 0;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<div class="container" x-data="fuzzyApp()" x-init="init()">

  <header>
    <a href="/" class="back-link">&larr; Kembali ke Beranda</a>
    <h1>Fuzzy Logic</h1>
    <p>Masukkan data sensor untuk analisis penyiraman</p>
  </header>

  <!-- Location -->
  <template x-if="location">
    <div class="location-card">
      <h2 x-text="location.desa + ', ' + location.kecamatan"></h2>
      <div class="location-detail">
        <span x-text="'Kota/Kab: ' + location.kotkab"></span>
        <span x-text="'Provinsi: ' + location.provinsi"></span>
        <span x-text="'Koordinat: ' + location.lat + ', ' + location.lon"></span>
      </div>
    </div>
  </template>

  <%- include('fuzzy/form') %>
  <%- include('fuzzy/result') %>

</div>

<%- include('fuzzy/charts') %>
<%- include('fuzzy/app') %>
